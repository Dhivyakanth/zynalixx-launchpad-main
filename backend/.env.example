# Server
PORT=5000

# CORS — comma-separated origins (your Firebase Hosting URL)
ALLOWED_ORIGINS=https://your-project.web.app,https://your-project.firebaseapp.com

# Firebase — use ONE of the following:
# Option A: JSON string (for Render production)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# Option B: file path (for local dev)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Resend email
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Zynalixx <contact@yourdomain.com>
EMAIL_TO=zynalixx@gmail.com
