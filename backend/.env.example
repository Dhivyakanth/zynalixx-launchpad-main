# Server
PORT=5000

# CORS - comma-separated origins (your frontend URLs)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000,https://zynalixx-a4c84.web.app,https://zynalixx-a4c84.firebaseapp.com

# Firebase - use ONE of the following:
# Option A: JSON string (recommended for production platforms like Render)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Option B: file path (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./zynalixx-a4c84-firebase-adminsdk-fbsvc-3d18c3ba05.json
FIRESTORE_PREFER_REST=true

# Resend email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Your Brand <onboarding@resend.dev>
EMAIL_TO=your-email@example.com

# Submission smoothing and resend retry/throttling
SUBMISSION_COOLDOWN_MS=700
RESEND_MIN_SEND_INTERVAL_MS=650
RESEND_RETRY_ATTEMPTS=3
RESEND_RETRY_BASE_DELAY_MS=500



